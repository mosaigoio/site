---
// IdeasSidebar.astro
// Shared sidebar navigation for /ideas/<subproject>/ pages.

export interface Props {
  active?:
    | "moscam"
    | "mospresent"
    | "mosbot"
    | "mosops"
    | "mostrade"
    | "depict"
    | "gtmd"
    | "storyarc"
    | "mosarch"
    | "mosdesk"
    | "sheetsync"
    | "teamtopo"
    | "gtmadvisor"
    | "aoc";
}

const { active } = Astro.props;

const distributions = [
  { key: "moscam", label: "moscam", href: "/ideas/moscam/" },
  { key: "mospresent", label: "mospresent", href: "/ideas/mospresent/" },
  { key: "mosbot", label: "mosbot", href: "/ideas/mosbot/" },
  { key: "mosops", label: "mosops", href: "/ideas/mosops/" },
  { key: "mostrade", label: "mostrade", href: "/ideas/mostrade/" },
  { key: "mosdesk", label: "mosdesk", href: "/ideas/mosdesk/" },
];

const intelligence = [
  { key: "depict", label: "depict", href: "/ideas/depict/" },
  { key: "gtmd", label: "gtmd", href: "/ideas/gtmd/" },
  { key: "storyarc", label: "storyarc", href: "/ideas/storyarc/" },
  { key: "mosarch", label: "mosarch", href: "/ideas/mosarch/" },
  { key: "sheetsync", label: "sheetsync", href: "/ideas/sheetsync/" },
  { key: "teamtopo", label: "teamtopo", href: "/ideas/teamtopo/" },
  { key: "gtmadvisor", label: "gtmadvisor", href: "/ideas/gtmadvisor/" },
];

const community = [
  { key: "aoc", label: "aoc", href: "/ideas/aoc/" },
];
---

<aside class="hub-sidebar">
  <a href="/ideas/" class="hub-sidebar-logo">
    <img src="/images/mozzy-icon.webp" alt="mosaigo" />
    Roadmap Ideas
  </a>

  <div class="hub-sidebar-section">Staging</div>
  <a href="/staging/" class="hub-sidebar-link">mosaigo</a>
  <a href="/staging/mosoptics/" class="hub-sidebar-link">mosoptics</a>
  <a href="/staging/mosii/" class="hub-sidebar-link">mosii</a>

  <div class="hub-sidebar-section">Distributions</div>
  {
    distributions.map((item) => (
      <a
        href={item.href}
        class={`hub-sidebar-link ${active === item.key ? "active" : ""}`}
      >
        {item.label}
        <span class="tag draft">idea</span>
      </a>
    ))
  }

  <div class="hub-sidebar-section">Intelligence</div>
  {
    intelligence.map((item) => (
      <a
        href={item.href}
        class={`hub-sidebar-link ${active === item.key ? "active" : ""}`}
      >
        {item.label}
        <span class="tag draft">idea</span>
      </a>
    ))
  }

  <div class="hub-sidebar-section">Community</div>
  {
    community.map((item) => (
      <a
        href={item.href}
        class={`hub-sidebar-link ${active === item.key ? "active" : ""}`}
      >
        {item.label}
        <span class="tag draft">idea</span>
      </a>
    ))
  }

  <div class="hub-sidebar-section">Resources</div>
  <a href="/getting-started/" class="hub-sidebar-link">Docs</a>
  <a href="/steps/" class="hub-sidebar-link">Step Catalog</a>
  <a href="https://github.com/mosaigoio" class="hub-sidebar-link">GitHub</a>

  <div class="hub-sidebar-footer">
    <p>
      These are <strong style="color:var(--accent);">roadmap ideas</strong>,
      early concepts exploring what mosaigo pipelines can enable.
      Browse the direction before anything gets built.
    </p>
  </div>
</aside>
