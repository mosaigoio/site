---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />
    <title>mosaigo — Event-Driven Pipeline Framework for Go</title>
    <meta
      name="description"
      content="mosaigo is a modular, event-driven pipeline framework for Go. Compose type-safe processing steps, observe everything in real time, and swap any piece without touching the rest."
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />
    <link rel="stylesheet" href="/assets/css/main.css" />
    <link rel="stylesheet" href="/assets/css/fontawesome-all.min.css" />
  </head>
  <body class="homepage is-preload">
    <div id="page-wrapper">

      <!-- Header -->
      <section id="header">

        <!-- Logo -->
        <h1><a href="/">mosaigo</a></h1>

        <!-- Nav -->
        <nav id="nav">
          <ul>
            <li class="current"><a href="/">Home</a></li>
            <li><a href="https://github.com/mosaigoio/mosaigo">GitHub</a></li>
          </ul>
        </nav>

        <!-- Banner -->
        <section id="banner">
          <header>
            <h2>Build pipelines like <strong>mosaics</strong></h2>
            <p>
              A modular, event-driven pipeline framework for Go. Type-safe steps,
              built-in observability, and zero-allocation hot paths. Coming soon.
            </p>
          </header>
        </section>

        <!-- Intro -->
        <section id="intro" class="container">
          <div class="row">
            <div class="col-4 col-12-medium">
              <section class="first">
                <i class="icon solid featured fa-puzzle-piece"></i>
                <header>
                  <h2>Type-Safe Steps</h2>
                </header>
                <p>Generic steps catch payload mismatches at compile time. Every step declares its input, output, and config through a single StepDef.</p>
              </section>
            </div>
            <div class="col-4 col-12-medium">
              <section class="middle">
                <i class="icon solid featured alt fa-bolt"></i>
                <header>
                  <h2>Zero-Alloc Hot Path</h2>
                </header>
                <p>Pre-allocated buffers and zero-copy passing. Init() allocates, Process() is allocation-free. Built for 120fps camera pipelines.</p>
              </section>
            </div>
            <div class="col-4 col-12-medium">
              <section class="last">
                <i class="icon solid featured alt2 fa-chart-bar"></i>
                <header>
                  <h2>Built-In Observability</h2>
                </header>
                <p>Every step tracks latency automatically. Topic pub/sub powers multi-engine architectures. Studio shows live pipeline graphs.</p>
              </section>
            </div>
          </div>
          <footer>
            <ul class="actions">
              <li><a href="https://github.com/mosaigoio/mosaigo" class="button large">View on GitHub</a></li>
            </ul>
          </footer>
        </section>

      </section>

      <!-- Main -->
      <section id="main">
        <div class="container">
          <div class="row">
            <div class="col-12">
              <section class="box" style="text-align: center;">
                <img src="/images/mozzy1.webp" alt="Mozzy, the mosaigo mascot" style="max-width: 360px; margin: 0 auto; display: block;" />
                <header>
                  <h2>Coming Soon</h2>
                </header>
                <p>
                  mosaigo is an open-source pipeline framework that treats every processing step like a tile in a mosaic.
                  Snap them together, observe them in real time, and swap any piece without touching the rest.
                  We're building the framework, the documentation, and the tooling right now.
                  Star the repo on GitHub to follow along.
                </p>
                <footer>
                  <ul class="actions">
                    <li><a href="https://github.com/mosaigoio/mosaigo" class="button large">Star on GitHub</a></li>
                  </ul>
                </footer>
              </section>
            </div>
          </div>
        </div>
      </section>

      <!-- Footer -->
      <section id="footer">
        <div class="container">
          <div class="row">
            <div class="col-12">
              <div id="copyright">
                <ul class="links">
                  <li>&copy; 2025-present mosaigoio contributors</li>
                  <li>Apache-2.0 License</li>
                  <li>Design: <a href="http://html5up.net">HTML5 UP</a></li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </section>

    </div>

    <!-- Scripts -->
    <script is:inline src="/assets/js/jquery.min.js"></script>
    <script is:inline src="/assets/js/jquery.dropotron.min.js"></script>
    <script is:inline src="/assets/js/browser.min.js"></script>
    <script is:inline src="/assets/js/breakpoints.min.js"></script>
    <script is:inline src="/assets/js/util.js"></script>
    <script is:inline src="/assets/js/main.js"></script>

  </body>
</html>
